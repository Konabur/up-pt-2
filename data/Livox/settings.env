# TLS Point Cloud Volume Estimation - Environment Variables
# Префикс: TPCVE (TLS Point Cloud Volume Estimation)
# Скопируйте в .env и настройте под свои нужды

# Путь к облаку точек для загрузки (.npz, .las, .laz, .pcd, .ply, .xyz, .pts, .db3)
# TPCVE_CLOUD=path/to/cloud.npz

# Путь для сохранения сгенерированного облака
# TPCVE_SAVE_CLOUD=output/cloud.npz

# Ground truth объём в м³ (для реальных облаков, если известен)
# TPCVE_GT_VOLUME=0.015

# Единицы измерения координат (auto, m, cm, mm)
# По умолчанию: auto (автоопределение)
# TPCVE_UNITS=auto

# Папка для сохранения результатов
# По умолчанию: results
# TPCVE_OUTPUT_DIR=results

# Дефолтный размер вокселя (м) для случая без GT
# По умолчанию: 0.007 (7мм) - эмпирически оптимальный для пшеницы
# Игнорируется если указан GT (тогда выбирается по минимуму ошибки)
# TPCVE_DEFAULT_VOXEL_SIZE=0.007

# Пропустить Convex Hull и Alpha Shape для ускорения (1/true/yes для включения)
# По умолчанию: не пропускать
# TPCVE_SKIP_HULL_METHODS=false

# Перевернуть ось Z (1/true/yes для включения)
# Полезно для облаков с инвертированной Z-осью
# По умолчанию: не переворачивать
TPCVE_FLIP_Z=true

# Коэффициент прореживания облака (0 = не прореживать)
# Значение > 0 применяет voxel downsampling с указанным размером вокселя
# По умолчанию: 0 (без прореживания)
TPCVE_DOWNSAMPLE=0.003

# Параметр std_ratio для Statistical Outlier Removal
# Чем больше значение, тем меньше точек удаляется как выбросы
# По умолчанию: 1.5
TPCVE_SOR_STD_RATIO=2.5

# Минимальное расстояние от начала координат (м)
# Точки ближе этого расстояния будут удалены (0 = не фильтровать)
# По умолчанию: 0 (без фильтрации)
TPCVE_MIN_RANGE=0.5
